{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "amigaassembly",
            "vasm": {
                "enabled": true,
                "command": "${config:amiga-assembly.binDir}/vasmm68k_mot",
                "args": [
                    "-m68000",
                    "-Fhunk",
                    "-linedebug"
                ]
            },
            "vlink": {
                "enabled": true,
                "command": "${config:amiga-assembly.binDir}/vlink",
                "includes": "*.{s,S,asm,ASM}",
                "excludes": "",
                "createStartupSequence": true,
                "createExeFileParentDir": true,
                "exefilename": "../uae/dh0/invaders",
                "args": [
                    "-bamigahunk",
                    "-Bstatic"
                ]
            },
            "problemMatcher": [],
            "label": "amigaassembly: build",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "amigaassembly",
            "adfgenerator": {
                "ADFToolsParentDir": "${config:amiga-assembly.binDir}",
                "sourceRootDir": "uae/dh0",
                "outputADFFile": "./build/invaders.adf",
                "includes": "**/*",
                "excludes": "**/.*",
                "adfCreateOptions": [
                    "--label=INVADERS"
                ]
            },
            "problemMatcher": [],
            "label": "amigaassembly: create ADF",
            "dependsOn": [
                "amigaassembly: build"
            ]
        }
    ]
}
