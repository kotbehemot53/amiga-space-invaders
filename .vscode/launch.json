{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "fs-uae",
            "request": "launch",
            "name": "FS-UAE Debug (A500)",
            "stopOnEntry": true,
            "serverName": "localhost",
            "serverPort": 6860,
            "startEmulator": true,
            "windows": {
                "emulator": "${config:amiga-assembly.binDir}/fs-uae.exe"
            },
            "emulatorWorkingDir": "${config:amiga-assembly.binDir}",
            "program": "${workspaceFolder}/uae/dh0/invaders",
            "options": [
                "--amiga_model=A500",
                "--kickstart_file=${workspaceFolder}/roms/kick13.rom",
                "--chip_memory=512",
                "--slow_memory=512",
                "--hard_drive_0=${workspaceFolder}/uae/dh0",
                "--joystick_port_1=keyboard",
                "--remote_debugger=200",
                "--use_remote_debugger=true",
                "--automatic_input_grab=0"
            ],
            "preLaunchTask": "amigaassembly: build"
        }
    ]
}
